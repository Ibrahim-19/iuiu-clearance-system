# Copy to .env and fill in real values for production use.
# Locally, leaving everything below blank still works (SQLite + local
# file storage). On Render, set all of these as environment variables in
# the dashboard instead of using a .env file.

SECRET_KEY=change-this-to-a-long-random-string

# Render provides this automatically when you attach a Postgres database
# to your web service. Leave blank locally to use SQLite.
DATABASE_URL=

# Cloudinary (https://cloudinary.com -> Dashboard -> Product Environment Credentials)
# Leave all three blank locally to fall back to local disk storage.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail SMTP (use an App Password if 2FA is enabled on the Gmail account)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_gmail_address@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_DEFAULT_SENDER=your_gmail_address@gmail.com
MAIL_SUPPRESS_SEND=0

# Finalist Eligibility Engine
CURRENT_ACADEMIC_YEAR=2026

# Set to 0 once you've loaded your real cohort data, to stop the demo
# finalist whitelist entry from being checked/recreated on every boot.
SEED_DEMO_DATA=1
